   "outputs": [],
   "source": [
    "import numpy as np \n",
    "from sklearn.decomposition import PCA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "312f644e",
   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(42)\n",
    "x=np.random.rand(100,6)*10"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "a959bc2f",
   "metadata": {},
   "outputs": [],
   "source": [
    "pca=PCA(n_components=2)\n",
    "x_pca=pca.fit_transform(x)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "564170eb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Original size: (100, 6)\n",
      "Original size: (100, 2)\n"
     ]
    }
   ],
   "source": [
    "print(\"Original size:\",x.shape)\n",
    "print(\"Original size:\",x_pca.shape)"
   ]
  }
 ],
